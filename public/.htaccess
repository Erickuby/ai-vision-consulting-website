DirectoryIndex index.html
ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Preserve former public URLs as permanent aliases.
  RewriteRule ^about/?$ /about-eric-nwankwo/ [R=301,L]
  RewriteRule ^services/?$ /ai-automation-consultant-newcastle/ [R=301,L]
  RewriteRule ^courses/?$ /ai-training-newcastle/ [R=301,L]
  RewriteRule ^blog/?$ /#blog [R=301,L,NE]
  RewriteRule ^privacy\.html$ /privacy-policy/ [R=301,L]

  # Replace dated or overly broad articles with focused evergreen guides.
  RewriteRule ^blog/how-to-start-an-ai-side-hustle-from-scratch-in-2026(?:\.html)?/?$ /blog/how-to-start-an-ai-side-hustle [R=301,L]
  RewriteRule ^blog/agentic-ai-and-automation-how-to-scale-your-business-career-work-and-life(?:\.html)?/?$ /blog/what-to-automate-first-small-business [R=301,L]

  # Canonicalise explicit index.html requests.
  RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
  RewriteRule ^index\.html$ / [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+(.+)/index\.html[\s?] [NC]
  RewriteRule ^(.+)/index\.html$ /$1/ [R=301,L]

  # The existing static blog uses clean URLs without a trailing slash.
  RewriteRule ^blog/([A-Za-z0-9-]+)/$ /blog/$1 [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+blog/([A-Za-z0-9-]+)\.html[\s?] [NC]
  RewriteRule ^blog/([A-Za-z0-9-]+)\.html$ /blog/$1 [R=301,L]

  RewriteCond %{DOCUMENT_ROOT}/blog/$1.html -f
  RewriteRule ^blog/([A-Za-z0-9-]+)$ /blog/$1.html [L]
</IfModule>

# There is deliberately no SPA catch-all. Physical route directories return
# crawlable HTML; unknown paths retain a genuine HTTP 404 status.
